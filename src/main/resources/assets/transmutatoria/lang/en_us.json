  "gui.transmutatoria.alchemy_slot.description.purge": "If this slot's essence deteriorates, it clears every adjacent produced item. This does not count as annihilation.",
  "gui.transmutatoria.alchemy_slot.description.restoration": "When this slot annihilates, its essence is retained instead of being cleared.",
  "gui.transmutatoria.alchemy_slot.description.resonance": "After reacting, adds the sum of all adjacent produced essence states to its own state.",
  "gui.transmutatoria.alchemy_slot.description.activity": "If this slot does not annihilate, it reacts again with the adjacent product indicated by the arrow. Matching essences annihilate each other; this reaction does not affect crucible polarity.",
  "gui.transmutatoria.alchemy_slot.description.exchange": "After reacting, swaps its product with the adjacent non-empty product indicated by the arrow.",
  "gui.transmutatoria.alchemy_slot.description.spin": "After all slots react, rotates all adjacent non-empty products clockwise.",
  "gui.transmutatoria.alchemy_slot.description.unstable": "If this slot's essence activates or deteriorates, it swaps its type with a random other slot after all slots react.",

